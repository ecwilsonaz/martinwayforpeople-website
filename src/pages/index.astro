---
import BaseLayout from '../layouts/BaseLayout.astro';
import SafetyMap from '../islands/SafetyMap.astro';
import { siteMeta } from '../data/site-meta';
---

<BaseLayout
  title={`${siteMeta.name} — Pedestrian Safety on Martin Way`}
  description={siteMeta.description}
  canonicalPath="/"
>

<main id="main-content">
<!-- ═══════════ HERO ═══════════ -->
<section class="min-h-screen flex flex-col justify-center px-6 max-w-3xl mx-auto pt-16 pb-20">
  <p class="text-sm font-semibold tracking-widest uppercase text-muted mb-6 animate-fade-up">
    4505 Martin Way E · Olympia, WA
  </p>
  <div class="animate-fade-up delay-1">
    <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-black leading-[1.08] tracking-tight">
      1,693 net new daily trips on a deadly&nbsp;corridor.
    </h1>
    <p class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold leading-[1.12] tracking-tight text-muted mt-3">
      For a&nbsp;Chick-fil-A.
    </p>
    <p class="font-display text-3xl sm:text-4xl lg:text-5xl font-black leading-[1.12] tracking-tight text-danger mt-3">
      Without studying pedestrian&nbsp;safety.
    </p>
  </div>
  <p class="mt-8 text-xl text-muted leading-relaxed max-w-2xl animate-fade-up delay-2">
    Martin Way has the highest rate of pedestrian fatalities and serious injuries in Thurston County — and pedestrian crashes are rising, not falling. A Chick-fil-A dual drive-through was approved here. The 90-page traffic study never analyzes pedestrian safety. We appealed. Permits are frozen. Now we need your voice.
  </p>
  <div class="mt-10 animate-fade-up delay-3">
    <button type="button"
       onclick="document.getElementById('action').scrollIntoView({behavior:'smooth'});history.replaceState(null,'',location.pathname)"
       class="inline-flex items-center gap-2 bg-danger text-white px-8 py-4 text-base font-semibold rounded hover:bg-danger-dark transition-colors cursor-pointer">
      Submit a public comment
      <svg class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
    </button>
  </div>
  <p class="mt-16 text-sm text-muted tracking-wide animate-fade-up delay-4">↓ Scroll to see the evidence</p>
</section>

<!-- ═══════════ STATS BAR ═══════════ -->
<section class="bg-ink text-white py-12 px-6">
  <div class="max-w-4xl mx-auto grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
    <div>
      <p class="font-display text-4xl sm:text-5xl font-black text-red-500">3,198</p>
      <p class="mt-2 text-sm text-muted-light">Crashes on Martin Way<br>2015–2025</p>
    </div>
    <div>
      <p class="font-display text-4xl sm:text-5xl font-black text-red-500">7 of 11</p>
      <p class="mt-2 text-sm text-muted-light">Fatalities involving a<br>pedestrian or cyclist</p>
    </div>
    <div>
      <p class="font-display text-4xl sm:text-5xl font-black text-blue-400">$1.6M</p>
      <p class="mt-2 text-sm text-muted-light">Programmed for Martin Way<br>pedestrian safety</p>
    </div>
    <div>
      <p class="font-display text-4xl sm:text-5xl font-black text-red-500">Zero</p>
      <p class="mt-2 text-sm text-muted-light">Pedestrian analysis<br>in the traffic study</p>
    </div>
  </div>
</section>

<!-- ═══════════ TREND ═══════════ -->
<section class="max-w-3xl mx-auto px-6 pt-16 pb-10">
  <p class="text-xs font-semibold tracking-[0.12em] uppercase text-muted mb-4">The trend</p>
  <h2 class="font-display text-3xl font-bold leading-snug mb-8">
    Crashes are declining.<br>
    <span class="text-danger">Pedestrians struck are&nbsp;not.</span>
  </h2>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
    <div>
      <p class="text-xs font-semibold tracking-[0.08em] uppercase text-muted mb-3">All crashes on Martin Way</p>
      <svg viewBox="0 0 286 120" xmlns="http://www.w3.org/2000/svg" class="w-full" role="img" aria-label="Bar chart showing total crashes on Martin Way declining from 334 in 2015 to 223 in 2025">
        <line x1="0" y1="100" x2="286" y2="100" stroke="#d6d0c4" stroke-width="1"/>
        <g fill="#857f79">
          <rect x="4" y="20.7" width="18" height="79.3" rx="2"/>
          <rect x="30" y="10.5" width="18" height="89.5" rx="2"/>
          <rect x="56" y="11.9" width="18" height="88.1" rx="2"/>
          <rect x="82" y="27.6" width="18" height="72.4" rx="2"/>
          <rect x="108" y="18.8" width="18" height="81.2" rx="2"/>
          <rect x="134" y="41.1" width="18" height="58.9" rx="2"/>
          <rect x="160" y="33.5" width="18" height="66.5" rx="2"/>
          <rect x="186" y="44.9" width="18" height="55.1" rx="2"/>
          <rect x="212" y="45.9" width="18" height="54.1" rx="2"/>
          <rect x="238" y="38.7" width="18" height="61.3" rx="2"/>
          <rect x="264" y="47.0" width="18" height="53.0" rx="2"/>
        </g>
        <g fill="#475569" font-family="'IBM Plex Sans',system-ui,sans-serif" font-size="9" text-anchor="middle">
          <text x="13" y="115">'15</text>
          <text x="39" y="115">'16</text>
          <text x="65" y="115">'17</text>
          <text x="91" y="115">'18</text>
          <text x="117" y="115">'19</text>
          <text x="143" y="115">'20</text>
          <text x="169" y="115">'21</text>
          <text x="195" y="115">'22</text>
          <text x="221" y="115">'23</text>
          <text x="247" y="115">'24</text>
          <text x="273" y="115">'25</text>
        </g>
      </svg>
      <div class="flex items-center gap-2 mt-3">
        <div>
          <p class="font-display text-xl font-bold leading-none">346</p>
          <p class="text-[10px] text-muted leading-tight">avg/yr<br>2015–19</p>
        </div>
        <svg class="w-4 h-4 text-muted flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <div>
          <p class="font-display text-xl font-bold leading-none">245</p>
          <p class="text-[10px] text-muted leading-tight">avg/yr<br>2020–25</p>
        </div>
        <p class="text-xs font-semibold text-green-deep ml-1">▼ 29%</p>
      </div>
    </div>

    <div>
      <p class="text-xs font-semibold tracking-[0.08em] uppercase text-danger mb-3">Pedestrians struck by vehicles</p>
      <svg viewBox="0 0 286 120" xmlns="http://www.w3.org/2000/svg" class="w-full" role="img" aria-label="Bar chart showing pedestrian crashes on Martin Way rising from 3 in 2015 to 10 in 2025, the highest year in the past decade">
        <line x1="0" y1="100" x2="286" y2="100" stroke="#d6d0c4" stroke-width="1"/>
        <g fill="#b91c1c">
          <rect x="4" y="76.3" width="18" height="23.8" rx="2"/>
          <rect x="30" y="68.3" width="18" height="31.7" rx="2"/>
          <rect x="56" y="76.3" width="18" height="23.8" rx="2"/>
          <rect x="82" y="36.7" width="18" height="63.3" rx="2"/>
          <rect x="108" y="76.3" width="18" height="23.8" rx="2"/>
          <rect x="134" y="60.4" width="18" height="39.6" rx="2"/>
          <rect x="160" y="52.5" width="18" height="47.5" rx="2"/>
          <rect x="186" y="44.6" width="18" height="55.4" rx="2"/>
          <rect x="212" y="44.6" width="18" height="55.4" rx="2"/>
          <rect x="238" y="44.6" width="18" height="55.4" rx="2"/>
          <rect x="264" y="20.8" width="18" height="79.2" rx="2"/>
        </g>
        <g fill="#b91c1c" font-family="'IBM Plex Sans',system-ui,sans-serif" font-size="9" font-weight="600" text-anchor="middle">
          <text x="13" y="72">3</text>
          <text x="39" y="64">4</text>
          <text x="65" y="72">3</text>
          <text x="91" y="33">8</text>
          <text x="117" y="72">3</text>
          <text x="143" y="56">5</text>
          <text x="169" y="48">6</text>
          <text x="195" y="41">7</text>
          <text x="221" y="41">7</text>
          <text x="247" y="41">7</text>
          <text x="273" y="17">10</text>
        </g>
        <g fill="#475569" font-family="'IBM Plex Sans',system-ui,sans-serif" font-size="9" text-anchor="middle">
          <text x="13" y="115">'15</text>
          <text x="39" y="115">'16</text>
          <text x="65" y="115">'17</text>
          <text x="91" y="115">'18</text>
          <text x="117" y="115">'19</text>
          <text x="143" y="115">'20</text>
          <text x="169" y="115">'21</text>
          <text x="195" y="115">'22</text>
          <text x="221" y="115">'23</text>
          <text x="247" y="115">'24</text>
          <text x="273" y="115">'25</text>
        </g>
      </svg>
      <div class="flex items-center gap-2 mt-3">
        <div>
          <p class="font-display text-xl font-bold text-danger leading-none">4.2</p>
          <p class="text-[10px] text-muted leading-tight">avg/yr<br>2015–19</p>
        </div>
        <svg class="w-4 h-4 text-danger flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <div>
          <p class="font-display text-xl font-bold text-danger leading-none">7.0</p>
          <p class="text-[10px] text-muted leading-tight">avg/yr<br>2020–25</p>
        </div>
        <p class="text-xs font-semibold text-danger ml-1">▲ 67%</p>
      </div>
    </div>
  </div>

  <p class="text-xs text-muted mt-6">Source: <a href="https://remoteapps.wsdot.wa.gov/highwaysafety/collision/data/portal/public/" class="text-muted underline hover:text-ink" target="_blank" rel="noopener">WSDOT Crash Data Portal<span class="sr-only">(opens in new tab)</span></a>, Thurston County, 2015–2025</p>
</section>

<!-- ═══════════ WHAT HAPPENED ═══════════ -->
<section class="max-w-3xl mx-auto px-6 py-20 border-t border-border">
  <p class="text-xs font-semibold tracking-[0.12em] uppercase text-muted mb-4">What happened</p>
  <h2 class="font-display text-3xl font-bold leading-snug mb-6">
    A 90-page traffic study that never mentions the people on foot
  </h2>
  <p class="text-muted text-lg leading-relaxed mb-4">
    In February 2026, the City of Olympia approved a new Chick-fil-A at 4505 Martin Way E. The project will add 1,693 vehicle trips per day to a four-lane undivided arterial. There are no marked pedestrian crossings near the site.
  </p>
  <p class="text-muted text-lg leading-relaxed mb-4">
    <a href="https://ci-olympia-wa.smartgovcommunity.com/Blob/94c1d95e-0e0d-46c3-8836-eac6b7eb1289" class="text-muted underline hover:text-ink" target="_blank" rel="noopener">The traffic study<span class="sr-only">(opens in new tab)</span></a>, prepared for Chick-fil-A, analyzes vehicle delay at five intersections. It runs about 90 pages. It contains no pedestrian counts. No pedestrian level-of-service analysis. No assessment of how 1,693 new daily trips affect people who walk along and cross Martin Way.
  </p>

  <div class="bg-danger-light border-l-4 border-danger rounded-r-lg px-7 py-6 my-8">
    <p class="text-danger-dark text-base">
      The <a href="https://www.trpc.org/martinway" class="text-danger-dark underline hover:text-ink" target="_blank" rel="noopener">Thurston Regional Planning Council<span class="sr-only">(opens in new tab)</span></a> identified the crossing at 4500 Martin Way — a manufactured housing community directly across the street from the project site — as one of only <strong>10 priority locations</strong> for new pedestrian crossings along the entire 7-mile corridor, scoring 23 out of 30 for pedestrian danger. Residents of the community cross Martin Way on foot to reach the bus stop. The traffic study does not reference this finding.
    </p>
  </div>

  <div class="bg-danger-light border-l-4 border-danger rounded-r-lg px-7 py-6 my-8">
    <p class="text-danger-dark text-base">
      The City's <a href="https://www.olympiawa.gov/services/transportation/index.php" class="text-danger-dark underline hover:text-ink" target="_blank" rel="noopener">Capital Facilities Plan<span class="sr-only">(opens in new tab)</span></a> programs $1.637 million for pedestrian safety on Martin Way — enhanced crosswalks and pedestrian-actuated signals between Pattison Street and Sleater-Kinney Road. The improvement zone ends half a mile west of the project site. The traffic study does not assess how 1,693 new daily trips affect the corridor the City is spending public money to make safer.
    </p>
  </div>

  <p class="text-muted text-lg leading-relaxed">
    Two bus stops within 225 feet of the proposed driveway see 107 daily boardings and alightings. These are people on foot, walking to and from stops on a road with no crosswalks. The traffic study says nothing about them.
  </p>

  <p class="text-muted text-lg leading-relaxed mt-6">
    On December 16, 2025, a pedestrian was struck and seriously injured at Martin Way and Lilly Road, less than a mile from the project site. It was one of 10 pedestrian crashes on the corridor that year, the most of any year in the past decade. Sixty-nine days later, the city approved the project.
  </p>
</section>

<!-- ═══════════ MAP ═══════════ -->
<section class="bg-ink py-20 px-6" id="map">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-8">
      <p class="text-xs font-semibold tracking-[0.12em] uppercase text-muted-light mb-4">The evidence</p>
      <h2 class="font-display text-3xl font-bold text-white mb-2">Every crash. Every bus stop. The project site.</h2>
      <p class="text-muted-light text-sm">Martin Way E corridor, 2015–2025 · Source: WSDOT, TRPC, Intercity Transit</p>
    </div>
    <SafetyMap />
    <div class="flex flex-wrap gap-6 justify-center mt-4">
      <span class="flex items-center gap-2 text-sm text-muted-light"><span class="w-2.5 h-2.5 rounded-full bg-[#f85149]" aria-hidden="true"></span> Pedestrian/cyclist crash</span>
      <span class="flex items-center gap-2 text-sm text-muted-light"><span class="w-2.5 h-2.5 rounded-full bg-[#da3633] ring-2 ring-white" aria-hidden="true"></span> Fatal crash</span>
      <span class="flex items-center gap-2 text-sm text-muted-light"><span class="w-2.5 h-2.5 rounded-full bg-[#3b5f8a] opacity-50" aria-hidden="true"></span> Vehicle crash</span>
      <span class="flex items-center gap-2 text-sm text-muted-light"><span class="w-2.5 h-2.5 rounded-full bg-[#3b82f6]" aria-hidden="true"></span> Bus stop</span>
      <span class="flex items-center gap-2 text-sm text-muted-light"><span class="w-2.5 h-2.5 rotate-45 bg-[#f59e0b]" aria-hidden="true"></span> Top-10 priority crossing</span>
      <span class="flex items-center gap-2 text-sm text-muted-light"><span class="w-2.5 h-2.5 rounded-full bg-[#22c55e]" aria-hidden="true"></span> Crossing location</span>
      <span class="flex items-center gap-2 text-sm text-muted-light"><span class="w-2.5 h-2.5 rounded-sm border-2 border-dashed border-[#dc2626] bg-[#dc2626]/20" aria-hidden="true"></span> Project site</span>
    </div>
  </div>
</section>

<!-- ═══════════ TAKE ACTION ═══════════ -->
<section class="bg-paper-warm py-20 px-6 border-t border-border" id="action">
  <div class="max-w-3xl mx-auto">

    <!-- Status banner -->
    <div class="bg-green-bg border border-green-border rounded-lg px-6 py-4 flex items-center gap-4 mb-8">
      <span class="w-3 h-3 bg-green-deep rounded-full flex-shrink-0 animate-pulse" aria-hidden="true"></span>
      <p class="text-green-deep text-sm font-medium">Appeal filed. All permits are frozen. A public hearing will be scheduled.</p>
    </div>

    <h2 class="font-display text-4xl font-black leading-tight mb-4">
      Your comment becomes part of the&nbsp;record
    </h2>
    <p class="text-muted text-lg mb-12">
      The hearing examiner reviews every public comment. This is how you put pedestrian safety into the official record.
    </p>

    <!-- Primary: Public Comment -->
    <div class="bg-white border-2 border-danger rounded-lg p-8 sm:p-10 mb-6">
      <span class="inline-block text-xs font-bold tracking-widest uppercase bg-danger-light text-danger px-3 py-1 rounded-full mb-4">Time-limited</span>
      <h3 class="font-display text-2xl font-bold mb-3">Submit a public comment</h3>
      <p class="text-muted text-base mb-4">
        Once the hearing is scheduled, there will be a window for written comments. Your comment goes directly to the hearing examiner.
      </p>

      <p class="font-semibold text-ink mb-3">What to focus on:</p>
      <ul class="space-y-2 mb-6">
        <li class="pl-7 relative text-muted text-base">
          <span class="absolute left-0 text-danger font-bold">→</span>
          The traffic study contains zero pedestrian safety analysis
        </li>
        <li class="pl-7 relative text-muted text-base">
          <span class="absolute left-0 text-danger font-bold">→</span>
          7 of 11 traffic fatalities on Martin Way involved a pedestrian or cyclist — and pedestrian crashes are increasing
        </li>
        <li class="pl-7 relative text-muted text-base">
          <span class="absolute left-0 text-danger font-bold">→</span>
          1,693 new daily trips next to bus stops with 107 daily boardings and alightings
        </li>
        <li class="pl-7 relative text-muted text-base">
          <span class="absolute left-0 text-danger font-bold">→</span>
          The city's Capital Facilities Plan programs $1.6M for Martin Way pedestrian safety — but the improvement zone ends half a mile west of this site, and the traffic study ignores the overlap
        </li>
        <li class="pl-7 relative text-muted text-base">
          <span class="absolute left-0 text-danger font-bold">→</span>
          The Thurston Regional Planning Council identified this location as a priority crossing
        </li>
      </ul>

      <details class="group mb-6">
        <summary class="cursor-pointer select-none inline-flex items-center gap-2 bg-white text-ink border border-border px-6 py-3 text-base font-semibold rounded hover:bg-paper transition-colors">
          <svg class="w-4 h-4 transition-transform group-open:rotate-90" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
          Template comment &amp; tips
        </summary>

        <div class="mt-4 space-y-3">
          <p class="text-muted text-sm">Copy and personalize before sending. Personal details carry more weight than form letters.</p>

          <div class="relative bg-paper border border-border rounded-lg p-6">
            <button type="button" data-copy-target="template-comment" aria-label="Copy comment template to clipboard" class="absolute top-3 right-3 inline-flex items-center gap-1.5 px-3 py-1.5 text-xs font-medium rounded-md bg-white border border-border text-muted hover:text-ink transition-colors">
              <svg class="copy-icon w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
              <svg class="check-icon w-3.5 h-3.5 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
              <span class="copy-label">Copy</span>
            </button>
            <div id="template-comment" class="text-sm text-muted leading-relaxed whitespace-pre-line pr-16">To the City of Olympia Hearing Examiner,

My name is [Your Name] and I [live / work / commute] [near Martin Way / in the Eastside neighborhood / along the Route 62 corridor]. I am writing regarding the proposed Chick-fil-A at 4505 Martin Way E (Project 25-3357).

Martin Way has the highest pedestrian fatality rate in Thurston County. Nearly half of fatal and serious collisions on this corridor involve pedestrians or cyclists. Despite this, the Traffic Impact Analysis for this project contains no pedestrian safety analysis.

The city is spending $1.637 million to make Martin Way safer for pedestrians — yet this project would add 1,693 net new daily vehicle trips to the same corridor, within 225 feet of a bus stop, with no evaluation of pedestrian impacts.

[Pick one or more and complete in your own words:]
- I use Martin Way to [walk / bike / catch the bus / drive to work] and I have personally [seen near-misses / felt unsafe crossing / worried about ...].
- Adding 1,693 daily vehicle trips to this corridor without studying pedestrian impacts is [reckless / an oversight / inconsistent with the city's own safety investments].

I ask that the city be required to complete a pedestrian safety analysis before this project proceeds.

[Your Name]
[Your Address or Neighborhood]</div>
          </div>
        </div>
      </details>

      <div class="bg-green-bg border border-green-border rounded-md px-5 py-4 mb-6">
        <p class="text-green-deep text-sm leading-relaxed">
          <strong class="block mb-1">Keep comments focused on pedestrian safety.</strong>
          The hearing examiner rules on whether the environmental review was adequate — not on corporate values or whether Olympia needs another chain restaurant. Comments about the missing pedestrian analysis carry the most weight.
        </p>
      </div>

      <form id="subscribe-form" action="/api/subscribe" method="POST" class="flex flex-col sm:flex-row gap-3">
        <label for="subscribe-email" class="sr-only">Email address</label>
        <input
          id="subscribe-email"
          name="email"
          type="email"
          required
          autocomplete="email"
          placeholder="you@example.com"
          aria-describedby="subscribe-status"
          class="flex-1 px-4 py-3 rounded border border-border bg-white text-ink text-base placeholder:text-muted focus:outline-none focus:ring-2 focus:ring-danger focus:border-danger"
        />
        <button
          type="submit"
          class="inline-flex items-center justify-center gap-2 bg-danger text-white px-6 py-3 text-base font-semibold rounded hover:bg-danger-dark transition-colors disabled:opacity-60"
        >
          <span class="btn-label">Notify me when comments open</span>
          <svg class="btn-spinner hidden w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8v4a4 4 0 00-4 4H4z"/></svg>
        </button>
      </form>
      <p id="subscribe-status" role="status" aria-live="polite" class="mt-3 text-sm min-h-[1.25rem]"></p>
      <p class="mt-2 text-xs text-muted">We'll email you when the public comment window opens and with other ways to help. <a href="/privacy" class="underline hover:text-ink">Privacy Policy</a></p>
    </div>

    <!-- Secondary: Council Email -->
    <div class="bg-white border border-border rounded-lg p-8 sm:p-10">
      <span class="inline-block text-xs font-bold tracking-widest uppercase bg-data-light text-data px-3 py-1 rounded-full mb-4">Ongoing</span>
      <h3 class="font-display text-2xl font-bold mb-3">Email your city council</h3>
      <p class="text-muted text-base mb-4">
        Council members can close the code gap that allowed this approval. Ask them to direct the Planning Commission to study drive-through compatibility with Martin Way corridor plans.
      </p>

      <p class="font-semibold text-ink mb-3">What to focus on:</p>
      <ul class="space-y-2 mb-4">
        <li class="pl-7 relative text-muted text-base">
          <span class="absolute left-0 text-data font-bold">→</span>
